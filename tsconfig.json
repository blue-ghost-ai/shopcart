{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM"],
    "paths": {
      "~/*": ["./*"],
      "~~/*": ["./*"],
      "@/*": ["./*"],
      "@@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.vue", "nuxt.config.ts"],
  "exclude": ["node_modules", ".nuxt", ".output", "dist"]
}
