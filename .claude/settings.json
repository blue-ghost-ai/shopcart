{
  "enabledMcpjsonServers": [
    "leftenant"
  ],
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(git *)",
      "Bash(cd * && git *)",
      "Bash(GIT_COMMITTER_NAME=* git:*)",
      "Bash(GIT_TERMINAL_PROMPT=0 git:*)",
      "Bash(npm *)",
      "Bash(npx vitest *)",
      "Bash(cd * && npx vitest *)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Glob",
      "Grep",
      "Read",
      "WebSearch",
      "mcp__leftenant__*"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|structured_choice|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/cate/needs-attention.mjs\"",
            "async": true
          }
        ]
      }
    ]
  }
}